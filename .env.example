# PostgreSQL running on your computer. Change this to match your local database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_substitution?schema=public"

# Use a long random value. Render generates this automatically from render.yaml.
SESSION_SECRET="replace-with-a-long-random-secret"

# Used only by `npm run db:bootstrap` to create the first administrator.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-strong-password"
